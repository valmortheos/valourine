{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/tracks.ts": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/tracks", "destination": "/api/tracks" },
    { "source": "/music/(.*)", "destination": "/music/$1" },
    { "source": "/musicthumb/(.*)", "destination": "/musicthumb/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
